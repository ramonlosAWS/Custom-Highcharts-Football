{
  "_comment": "Sort Direction Control. Click column headers to sort. Click active column to toggle ASC/DESC. Uses two parameters: SortColumn and SortDirection. Navigation action sets both.",
  "_quicksight_setup": {
    "parameters": ["SortColumn (String, default: 'Rating')", "SortDirection (String, default: 'DESC')"],
    "calc_fields": ["ActiveSortCol = ${SortColumn}", "ActiveSortDir = ${SortDirection}"],
    "target_dataset_usage": "Use ${SortColumn} and ${SortDirection} in a calculated field to create a sort key, then sort your visual by that field."
  },
  "chart": {
    "type": "scatter",
    "backgroundColor": "transparent",
    "height": 70,
    "spacing": [5, 5, 5, 5],
    "animation": false,
    "style": { "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" }
  },
  "title": { "text": null },
  "legend": { "enabled": false },
  "credits": { "enabled": false },
  "xAxis": { "min": 0, "max": 100, "visible": false },
  "yAxis": { "min": 0, "max": 100, "visible": false },
  "tooltip": { "enabled": false },
  "plotOptions": {
    "scatter": { "marker": { "enabled": false }, "animation": false },
    "series": { "enableMouseTracking": true, "cursor": "pointer", "animation": false }
  },
  "series": [{
    "name": "SortHeaders",
    "data": [
      "map",
      ["getColumn", 0, 1, 2],
      {
        "x": ["+", 8, ["*", ["itemIndex"], 18]],
        "y": 50,
        "colName": ["get", ["item"], 0],
        "marker": { "enabled": false },
        "dataLabels": {
          "enabled": true,
          "useHTML": true,
          "format": "<div style='padding:6px 12px;border-radius:6px;background:#f7fafc;border:1px solid #e2e8f0;color:#4a5568;font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;box-shadow:0 1px 2px rgba(0,0,0,0.04);'>{point.colName}</div>",
          "align": "center",
          "verticalAlign": "middle",
          "style": { "textOutline": "none" }
        }
      }
    ],
    "point": { "events": { "click": ["triggerClick", { "rowIndex": "point.index" }] } }
  }],
  "quicksight": {
    "pointRender": ["updatePointAttributes", {
      "dataLabels": {
        "format": [
          "case",
          ["==", "point.colName", ["get", ["getColumn", 1], 0]],
          ["+",
            "<div style='padding:6px 12px;border-radius:6px;background:#2d3748;border:1px solid #2d3748;color:#fff;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;box-shadow:0 2px 6px rgba(0,0,0,0.15);'>{point.colName} <span style=\"font-size:14px;\">",
            ["case", ["==", ["get", ["getColumn", 2], 0], "ASC"], "↑", "↓"],
            "</span></div>"
          ],
          "<div style='padding:6px 12px;border-radius:6px;background:#f7fafc;border:1px solid #e2e8f0;color:#4a5568;font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;box-shadow:0 1px 2px rgba(0,0,0,0.04);'>{point.colName}</div>"
        ]
      }
    }]
  }
}
