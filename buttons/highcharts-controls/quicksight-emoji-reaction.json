{
  "_comment": "Emoji Reaction Bar. Click an emoji to select it. Selected emoji scales up with indicator dot.",
  "chart": {
    "type": "scatter",
    "backgroundColor": "transparent",
    "height": 80,
    "spacing": [5, 5, 5, 5],
    "animation": false,
    "style": { "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" }
  },
  "title": { "text": null },
  "legend": { "enabled": false },
  "credits": { "enabled": false },
  "xAxis": { "min": 0, "max": 100, "visible": false },
  "yAxis": { "min": 0, "max": 100, "visible": false },
  "tooltip": { "enabled": false },
  "plotOptions": {
    "scatter": { "marker": { "enabled": false }, "animation": false },
    "series": { "enableMouseTracking": true, "cursor": "pointer", "animation": false }
  },
  "series": [{
    "name": "Emojis",
    "data": [
      "map",
      ["getColumn", 0, 1, 2],
      {
        "x": ["+", 15, ["*", ["itemIndex"], 14]],
        "y": 50,
        "emojiIcon": ["get", ["item"], 0],
        "emojiLabel": ["get", ["item"], 1],
        "marker": { "enabled": false },
        "dataLabels": {
          "enabled": true,
          "useHTML": true,
          "format": "<div style='text-align:center;cursor:pointer;'><div style='font-size:24px;'>{point.emojiIcon}</div><div style='font-size:9px;color:#a0aec0;font-weight:400;margin-top:2px;'>{point.emojiLabel}</div></div>",
          "align": "center",
          "verticalAlign": "middle",
          "style": { "textOutline": "none" }
        }
      }
    ],
    "point": { "events": { "click": ["triggerClick", { "rowIndex": "point.index" }] } }
  }],
  "quicksight": {
    "pointRender": ["updatePointAttributes", {
      "dataLabels": {
        "format": [
          "case",
          ["==", "point.emojiIcon", ["get", ["getColumn", 2], 0]],
          "<div style='text-align:center;cursor:pointer;'><div style='font-size:34px;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));'>{point.emojiIcon}</div><div style='font-size:9px;color:#2b6cb0;font-weight:700;margin-top:2px;'>{point.emojiLabel}</div><div style='width:4px;height:4px;border-radius:50%;background:#3182ce;margin:3px auto 0;'></div></div>",
          "<div style='text-align:center;cursor:pointer;'><div style='font-size:24px;'>{point.emojiIcon}</div><div style='font-size:9px;color:#a0aec0;font-weight:400;margin-top:2px;'>{point.emojiLabel}</div></div>"
        ]
      }
    }]
  }
}
