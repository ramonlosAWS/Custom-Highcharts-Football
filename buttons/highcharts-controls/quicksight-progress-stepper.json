{
  "_comment": "Progress Stepper / Wizard. Dataset: one row per step with StepNum, StepLabel, SelectedStep (calc field). Circles + connector lines + labels.",
  "chart": {
    "type": "scatter",
    "backgroundColor": "transparent",
    "height": 90,
    "spacing": [5, 5, 5, 5],
    "animation": false,
    "style": { "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" }
  },
  "title": { "text": null },
  "legend": { "enabled": false },
  "credits": { "enabled": false },
  "xAxis": { "min": 0, "max": 100, "visible": false },
  "yAxis": { "min": 0, "max": 100, "visible": false },
  "tooltip": { "enabled": false },
  "plotOptions": {
    "scatter": { "marker": { "enabled": false }, "animation": false },
    "series": { "enableMouseTracking": true, "cursor": "pointer", "animation": false }
  },
  "series": [
    {
      "_comment": "Connector lines between steps - visual only",
      "name": "Connectors",
      "enableMouseTracking": false,
      "data": [
        "map",
        ["getColumn", 0, 1, 2],
        {
          "x": ["+", 17, ["*", ["itemIndex"], 22]],
          "y": 60,
          "marker": { "enabled": false },
          "dataLabels": {
            "enabled": ["case", ["==", ["itemIndex"], ["-", ["length", ["getColumn", 0]], 1]], false, true],
            "useHTML": true,
            "format": "<div style='width:44px;height:3px;background:#e2e8f0;border-radius:1.5px;'></div>",
            "align": "center",
            "verticalAlign": "middle",
            "style": { "textOutline": "none" }
          }
        }
      ]
    },
    {
      "_comment": "Step circles - clickable",
      "name": "Steps",
      "data": [
        "map",
        ["getColumn", 0, 1, 2],
        {
          "x": ["+", 15, ["*", ["itemIndex"], 22]],
          "y": 60,
          "stepNum": ["get", ["item"], 0],
          "stepLabel": ["get", ["item"], 1],
          "marker": { "enabled": false },
          "dataLabels": {
            "enabled": true,
            "useHTML": true,
            "format": "<div style='width:32px;height:32px;border-radius:50%;background:#edf2f7;border:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#a0aec0;cursor:pointer;'>{point.stepNum}</div>",
            "align": "center",
            "verticalAlign": "middle",
            "style": { "textOutline": "none" }
          }
        }
      ],
      "point": { "events": { "click": ["triggerClick", { "rowIndex": "point.index" }] } }
    },
    {
      "_comment": "Step labels below circles",
      "name": "Labels",
      "enableMouseTracking": false,
      "data": [
        "map",
        ["getColumn", 0, 1, 2],
        {
          "x": ["+", 15, ["*", ["itemIndex"], 22]],
          "y": 22,
          "marker": { "enabled": false },
          "dataLabels": {
            "enabled": true,
            "useHTML": true,
            "format": "<div style='font-size:10px;color:#a0aec0;font-weight:500;text-align:center;white-space:nowrap;'>{point.stepLabel}</div>",
            "align": "center",
            "verticalAlign": "middle",
            "style": { "textOutline": "none" }
          }
        }
      ]
    }
  ],
  "quicksight": {
    "pointRender": ["updatePointAttributes", {
      "dataLabels": {
        "format": [
          "case",
          ["<", "point.stepNum", ["get", ["getColumn", 2], 0]],
          "<div style='width:32px;height:32px;border-radius:50%;background:#48bb78;border:2px solid #48bb78;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;cursor:pointer;'>✓</div>",
          ["==", "point.stepNum", ["get", ["getColumn", 2], 0]],
          "<div style='width:32px;height:32px;border-radius:50%;background:#3182ce;border:2px solid #3182ce;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;cursor:pointer;box-shadow:0 0 0 4px rgba(49,130,206,0.2);'>{point.stepNum}</div>",
          "<div style='width:32px;height:32px;border-radius:50%;background:#edf2f7;border:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#a0aec0;cursor:pointer;'>{point.stepNum}</div>"
        ]
      }
    }]
  }
}
