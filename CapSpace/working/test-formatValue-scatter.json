{
  "chart": {
    "type": "scatter",
    "backgroundColor": "#ffffff",
    "height": 300
  },
  "title": { "text": "formatValue in Scatter Data Point Test" },
  "legend": { "enabled": false },
  "credits": { "enabled": false },
  "xAxis": { "min": 0, "max": 100, "visible": false },
  "yAxis": { "min": 0, "max": 100, "visible": false },
  "tooltip": { "enabled": false },
  "plotOptions": {
    "scatter": {
      "marker": { "enabled": false },
      "enableMouseTracking": false
    }
  },
  "series": [
    {
      "name": "Test1",
      "data": [{
        "x": 50,
        "y": 30,
        "displayVal": ["formatValue", ["get", ["getColumnFromValue", 0], 0], 0]
      }],
      "dataLabels": {
        "enabled": true,
        "useHTML": true,
        "format": "<div style='font-size:24px;font-weight:700;color:#333;'>Test A: {point.displayVal}</div>",
        "align": "center",
        "verticalAlign": "middle",
        "style": { "textOutline": "none" }
      }
    },
    {
      "name": "Test2",
      "data": [{
        "x": 50,
        "y": 60,
        "rawVal": ["get", ["getColumnFromValue", 0], 0]
      }],
      "dataLabels": {
        "enabled": true,
        "useHTML": true,
        "format": "<div style='font-size:24px;font-weight:700;color:#999;'>Test B (raw): {point.rawVal}</div>",
        "align": "center",
        "verticalAlign": "middle",
        "style": { "textOutline": "none" }
      }
    }
  ]
}
