  "_comment": "TeamFitFilter Mobile 1024px - 4 buttons: TEAM FIT, TOP 101, OUTGOING, CUT CANDIDATES. Single row. Parameter: TeamFitFilter. Dataset: team-fit-filter-data.csv + calc SelectedTeamFit = ${TeamFitFilter}. Field Wells GROUP BY: SortOrder (col 0), ButtonLabel (col 1), SelectedTeamFit (col 2).",
  "series": [
    {
      "name": "TeamFitFilter",
      "data": [
        "map",
        [
          "getColumn",
          1,
          2
        ],
        {
          "x": [
            "+",
            22.76,
            [
              "*",
              [
                "itemIndex"
              ],
