      "name": "ALL",
      "data": [{ "x": 4, "y": 50, "position": "ALL" }],
      "dataLabels": {
        "enabled": true,
        "useHTML": true,
        "format": "<div style='background:#0073bb;color:#fff;padding:8px 14px;border-radius:4px;cursor:pointer;font-weight:600;font-size:12px;min-width:40px;text-align:center;border:2px solid #0073bb;'>{point.position}</div>",
        "align": "center",
        "verticalAlign": "middle",
        "style": { "textOutline": "none" }
